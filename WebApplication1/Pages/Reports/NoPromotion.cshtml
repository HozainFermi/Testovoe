@page
@model WebApplication1.Pages.Reports.NoPromotionModel
@{
    ViewData["Title"] = "Сотрудники без повышения";
}

<h2>Сотрудники без повышения ЗП</h2>

<table class="table">
    <thead>
        <tr><th>Табельный номер</th><th>ФИО</th><th>Подразделение</th><th>Дата приёма</th></tr>
    </thead>
    <tbody>
        @foreach (var e in Model.Employees)
        {
            <tr><td>@e.StuffNumber</td><td>@e.FullName</td><td>@e.DepartmentName</td><td>@e.HireDate.ToString("dd.MM.yyyy")</td></tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-page="/Reports/Promotions" class="btn btn-info">Сотрудники c повышения</a>
</div>