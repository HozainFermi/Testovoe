@page
@model WebApplication1.Pages.Employees.CreateModel
@{
    ViewData["Title"] = "Добавление сотрудника";
}

<h2>Добавление сотрудника</h2>

<form method="post">
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Input.StuffNumber" class="form-label">Табельный номер</label>
            <input asp-for="Input.StuffNumber" class="form-control" />
            <span asp-validation-for="Input.StuffNumber" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.FullName" class="form-label">ФИО</label>
            <input asp-for="Input.FullName" class="form-control" />
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.BirthDate" class="form-label">Дата рождения</label>
            <input asp-for="Input.BirthDate" type="date" class="form-control" />
            <span asp-validation-for="Input.BirthDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.HireDate" class="form-label">Дата приёма</label>
            <input asp-for="Input.HireDate" type="date" class="form-control" />
            <span asp-validation-for="Input.HireDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.FiredDate" class="form-label">Дата увольнения</label>
            <input asp-for="Input.FiredDate" type="date" class="form-control" />
            <span asp-validation-for="Input.FiredDate" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.DepartmentId" class="form-label">Подразделение</label>
            <select asp-for="Input.DepartmentId" class="form-select" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))">
                <option value="">-- Выберите --</option>
            </select>
            <span asp-validation-for="Input.DepartmentId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.EducationId" class="form-label">Образование</label>
            <select asp-for="Input.EducationId" class="form-select" asp-items="@(new SelectList(Model.Educations, "Id", "Name"))">
                <option value="">-- Выберите --</option>
            </select>
            <span asp-validation-for="Input.EducationId" class="text-danger"></span>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}