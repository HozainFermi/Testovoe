@page
@model WebApplication1.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Список сотрудников";
}

<h2>Список сотрудников</h2>

<!-- Форма фильтрации -->
<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label asp-for="Filter.FullName" class="form-label">ФИО</label>
        <input asp-for="Filter.FullName" class="form-control" placeholder="Поиск по ФИО" />
    </div>
    <div class="col-md-3">
        <label asp-for="Filter.DepartmentId" class="form-label">Подразделение</label>
        <select asp-for="Filter.DepartmentId" class="form-select">
            <option value="">-- Все --</option>
            @foreach (var dept in Model.Departments)
            {
                <option value="@dept.Id">@dept.Name</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="Filter.EducationId" class="form-label">Образование</label>
        <select asp-for="Filter.EducationId" class="form-select">
            <option value="">-- Все --</option>
            @foreach (var edu in Model.Educations)
            {
                <option value="@edu.Id">@edu.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Фильтровать</button>
    </div>
</form>

<!-- Таблица сотрудников -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>Табельный номер</th>
            <th>ФИО</th>
            <th>Дата рождения</th>
            <th>Подразделение</th>
            <th>Образование</th>
            <th>Дата приёма</th>
            <th>Дата увольнения</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model.Employees)
        {
            <tr>
                <td>@emp.StuffNumber</td>
                <td>@emp.FullName</td>
                <td>@emp.BirthDate.ToString("dd.MM.yyyy")</td>
                <td>@emp.DepartmentName</td>
                <td>@emp.EducationName</td>
                <td>@emp.HireDate.ToString("dd.MM.yyyy")</td>
                <td>@(emp.FiredDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@emp.Id" style="display:inline;" onsubmit="return confirm('Удалить?')">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Пагинация -->
@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-page="/Employees/Index" 
                       asp-route-currentPage="@i"
                       asp-route-filter.FullName="@Model.Filter.FullName"
                       asp-route-filter.DepartmentId="@Model.Filter.DepartmentId"
                       asp-route-filter.EducationId="@Model.Filter.EducationId">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<div class="mt-3">
    <a asp-page="Create" class="btn btn-success">Добавить сотрудника</a>    
</div>